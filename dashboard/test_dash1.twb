            <column caption='Top 10 Profit &amp; Loss' datatype='boolean' name='[Calculation_1520083351150597]' role='measure' type='nominal'>
              <calculation class='tableau' formula='RANK(SUM([Profit]), &apos;desc&apos;) &lt;= 10&#13;&#10;OR&#13;&#10;RANK(SUM([Profit]), &apos;asc&apos;) &lt;= 10'>
                <table-calc ordering-type='Rows' />
