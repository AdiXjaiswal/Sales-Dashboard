      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0joxts71wzrp301768tzm0b3fjr0].[ctd:Customer ID:qk]&quot;' value='No of Customers' />
          <alias key='&quot;[federated.0joxts71wzrp301768tzm0b3fjr0].[ctd:Order ID:qk]&quot;' value='No of  Orders' />
        </aliases>
      </column>
      <column caption='profit margin' datatype='real' name='[Calculation_1409307342831617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='Profit Status' datatype='string' name='[Calculation_1520083326758912]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit]&gt;0 THEN &quot;Profit&quot;&#13;&#10;ELSE &quot;Loss&quot;&#13;&#10;END' />
      </column>
      <column caption='Top 10 Profit &amp; Loss' datatype='boolean' name='[Calculation_1520083351150597]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Profit]), &apos;desc&apos;) &lt;= 10&#13;&#10;OR&#13;&#10;RANK(SUM([Profit]), &apos;asc&apos;) &lt;= 10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Profit vs Loss' datatype='string' name='[Calculation_1520083351801862]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) &gt; 0 THEN &quot;Profit&quot;&#13;&#10;ELSE &quot;Loss&quot;&#13;&#10;END' />
      </column>
      <column caption='sales rank' datatype='boolean' name='[Calculation_1520083354292232]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Sales]),&apos;desc&apos;) &lt;=10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sales MA 3' datatype='real' name='[Calculation_1520083358666761]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([Sales]),-2,0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sales MA 6' datatype='real' name='[Calculation_1520083358957578]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([Sales]),-5,0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
